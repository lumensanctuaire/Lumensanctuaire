# ─────────────────────────────────────────────────────────────────────
# LUMEN — Variables d'environnement
# ─────────────────────────────────────────────────────────────────────
# Copier ce fichier en `.env.local` et remplir avec les valeurs réelles.
# Ne jamais committer `.env.local`.
# ─────────────────────────────────────────────────────────────────────


# ── Authentification membre (JWT signé) ─────────────────────────────
# Clé secrète utilisée par `jose` pour signer le cookie `lumen_token`.
# Doit être une chaîne longue et aléatoire (≥ 32 caractères).
# Générer avec : openssl rand -base64 48
JWT_SECRET=


# ── Stripe — Paiement du passage (190 €, mode payment) ──────────────
# Clé secrète Stripe (sk_test_… en dev, sk_live_… en prod).
# Dashboard : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Secret de signature des webhooks Stripe (whsec_…).
# Récupéré lors de la création du endpoint webhook ou via Stripe CLI.
# Dashboard : https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=


# ── URL publique du sanctuaire ──────────────────────────────────────
# Utilisée par Stripe pour les redirections success_url / cancel_url.
# En local : http://localhost:3000
# En production : https://lumen.ton-domaine.com
NEXT_PUBLIC_URL=http://localhost:3000


# ── Brevo — Liste de diffusion (route /api/subscribe) ───────────────
# Clé API Brevo (xkeysib-…).
# Dashboard : https://app.brevo.com/settings/keys/api
# Optionnelle : la route renvoie 500 proprement si manquante.
BREVO_API_KEY=
